{
  "expectation_suite_name": "silver_suite",
  "expectations": [
    {
      "expectation_type": "expect_column_to_exist",
      "kwargs": {"column": "observed_at"}
    },
    {
      "expectation_type": "expect_column_values_to_not_be_null",
      "kwargs": {"column": "city_name"}
    },
    {
      "expectation_type": "expect_column_values_to_not_be_null",
      "kwargs": {"column": "temp_celsius"}
    },
    {
      "expectation_type": "expect_column_values_to_be_in_set",
      "kwargs": {
        "column": "temp_category",
        "value_set": ["freezing", "cold", "mild", "warm", "hot"]
      }
    },
    {
      "expectation_type": "expect_column_values_to_be_in_set",
      "kwargs": {
        "column": "wind_category",
        "value_set": ["calm", "light", "moderate", "strong", "storm"]
      }
    },
    {
      "expectation_type": "expect_column_values_to_be_between",
      "kwargs": {"column": "dq_score", "min_value": 0, "max_value": 100}
    }
  ],
  "meta": {"great_expectations_version": "0.18.x"}
}
